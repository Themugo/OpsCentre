# Resend (Email)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=FiberCRM

# Notifications
SUPPORT_PHONES=+254712345678,+254722345678
SUPPORT_PHONE=0800000000

# Cron
CRON_SECRET=generate-with-openssl-rand-hex-32

# Sentry (optional)
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────────────────
# Setup: developers.facebook.com → Create App → WhatsApp product
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxx
WHATSAPP_WEBHOOK_VERIFY=fibercrm-verify-token
# Webhook URL to register in Meta dashboard:
#   https://yourdomain.com/api/whatsapp
# Required message templates (create in Meta Business Manager):
#   invoice_ready, payment_received, outage_alert, welcome_customer
